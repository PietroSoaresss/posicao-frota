# PAVI API secrets template — copy to .env and fill in.
# .env is gitignored; .env.example is the committed reference.

# JWT — secret must be at least 256 bits (32 chars). Rotate periodically.
JWT_SECRET=
JWT_EXPIRATION_HOURS=8

# Session cookie. SameSite=Strict suits a single-domain SPA (the API and the
# SPA are served from the same registrable domain). Set to None and turn
# cookie-secure on if hosting the SPA on a different domain than the API.
# cookie-secure must be true in production (set in application-prod.properties).
# APP_SESSION_COOKIE_SAME_SITE=Strict

# CORS — comma-separated list of allowed front-end origins.
# Local dev: http://localhost:4200
# Production: https://app.your-domain.com,https://admin.your-domain.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Rate limit — set to true ONLY when behind a trusted ALB/Nginx that overwrites X-Forwarded-For.
APP_RATE_LIMIT_TRUST_FORWARDED_FOR=false

# PostgreSQL
# Local: jdbc:postgresql://localhost:5432/pavi
# RDS:   jdbc:postgresql://pavi.xxxxxxxx.us-east-1.rds.amazonaws.com:5432/pavi
DATABASE_URL=jdbc:postgresql://localhost:5432/pavi
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Sascar / SASINTEGRA
SASCAR_USER=
SASCAR_PASSWORD=
