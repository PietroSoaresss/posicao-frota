{
  "info": {
    "name": "Pavi API",
    "description": "Collection do Pavi API. Faça Login primeiro — o token é salvo automaticamente na variavel de ambiente {{token}} e usado nos demais requests. Se a API subir em outra porta, ajuste {{baseUrl}} no environment antes de rodar os testes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Tem token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('token', body.token);",
                  "console.log('Token salvo:', body.token.substring(0, 20) + '...');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Smoke Tests",
      "description": "Teste rapido para validar autenticacao, acesso a rota protegida e bloqueio sem token.",
      "item": [
        {
          "name": "01 - Login salva token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna token JWT', () => {",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.token.split('.')).to.have.length(3);",
                  "});",
                  "pm.environment.set('token', body.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "02 - States exige autenticacao",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403 sem token', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/states", "host": ["{{baseUrl}}"], "path": ["states"] }
          }
        },
        {
          "name": "03 - States com token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna uma lista', () => pm.expect(body).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/states", "host": ["{{baseUrl}}"], "path": ["states"] }
          }
        },
        {
          "name": "04 - Login + validacao de rota protegida",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 no login', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna token JWT', () => {",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.token.split('.')).to.have.length(3);",
                  "});",
                  "pm.environment.set('token', body.token);",
                  "",
                  "pm.sendRequest({",
                  "  url: `${pm.environment.get('baseUrl')}/states`,",
                  "  method: 'GET',",
                  "  header: { Authorization: `Bearer ${body.token}` }",
                  "}, (err, res) => {",
                  "  pm.test('GET /states nao falha', () => pm.expect(err).to.equal(null));",
                  "  pm.test('GET /states autenticado retorna 200', () => pm.expect(res.code).to.eql(200));",
                  "  const list = res.json();",
                  "  pm.test('GET /states autenticado retorna array', () => pm.expect(list).to.be.an('array'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
